# Copy to `.env.local` (gitignored). Server-side only — never shipped to the browser.
#
# Base URL of the FastAPI engine API the Next route handlers proxy to.
#   local dev: the uvicorn server (uvicorn settl.api.main:app --port 8000)
#   prod:      your Cloud Run URL, e.g. https://settl-api-xxxx.run.app
SETTL_API_BASE_URL=http://localhost:8000

# Shared secret the proxy attaches to prove a forwarded Google identity is real -
# the engine is publicly reachable directly, so it must never trust an identity
# header without this. Same value must be set on the engine host (Cloud Run) as
# SETTL_INTERNAL_SECRET. Generate with e.g. `openssl rand -hex 32`.
SETTL_INTERNAL_SECRET=

