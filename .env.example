SETTL_SMTP_USER=
SETTL_SMTP_APP_PASSWORD=
SETTL_TEST_RECIPIENT=

# Gemini judgment model (Week 3). Get a free key at https://aistudio.google.com/apikey
# Without a key the strategy agent stays fully deterministic (no model calls).
GEMINI_API_KEY=
# The Gemini model id (judgment + drafting). Code defaults to gemini-3-pro-preview
# (per DESIGN). Free-tier keys usually lack quota for 3-pro-preview (429) - set a
# free-tier model like gemini-2.5-flash for local demos. Blank = code default.
GEMINI_MODEL=

# Opt in to REAL Gemini drafting in the dashboard board (the visible AI in Approvals).
# Needs GEMINI_API_KEY above. Off by default so the board run + test suite stay
# offline/deterministic (mirrors SETTL_LIVE_SEND for email). Set to 1 to test Gemini.
SETTL_USE_GEMINI=
