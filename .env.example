# Settl — local environment template.
#
# Copy this to `.env` and fill in real values:  cp .env.example .env
# `.env` is gitignored and never committed. This template is safe to commit.
#
# --- Gmail SMTP (real email self-test: send_live.py) ---
# SETTL_SMTP_USER:         your Gmail address (the authenticated sender)
# SETTL_SMTP_APP_PASSWORD: a Gmail *App Password*, NOT your normal login password.
#   Create one at: Google Account → Security → 2-Step Verification → App passwords
#   (2-Step Verification must be ON). It looks like: "abcd efgh ijkl mnop".
# SETTL_TEST_RECIPIENT:    where the self-test email lands (use your own inbox).
#   Every live send is force-redirected here so a synthetic debtor address can
#   never be emailed by accident.

SETTL_SMTP_USER=
SETTL_SMTP_APP_PASSWORD=
SETTL_TEST_RECIPIENT=
