SETTL_SMTP_USER=
SETTL_SMTP_APP_PASSWORD=
SETTL_TEST_RECIPIENT=

# Gemini judgment model (Week 3). Get a free key at https://aistudio.google.com/apikey
# Without a key the strategy agent stays fully deterministic (no model calls).
GEMINI_API_KEY=
# The judgment model id. Code defaults to gemini-3-pro-preview (per DESIGN).
# Free-tier keys usually lack quota for 3-pro-preview (429) - set a free-tier model
# like gemini-2.5-flash for local demos. Leave blank to use the code default.
GEMINI_MODEL=
